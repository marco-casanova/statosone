# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# KinRelay Supabase project
# https://dkujyucpykkafnxmperx.supabase.co

# Public URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://dkujyucpykkafnxmperx.supabase.co

# Current browser-safe key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key

# Legacy fallback for older helpers that still read the anon env name
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key

# Server-side URL / DB connection
SUPABASE_URL=https://dkujyucpykkafnxmperx.supabase.co
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.dkujyucpykkafnxmperx.supabase.co:5432/postgres

# Current server-side secret key
SUPABASE_SECRET_KEY=sb_secret_your_secret_key

# Legacy fallback for older helpers that still read the service role env name
SUPABASE_SERVICE_ROLE=sb_secret_your_secret_key

# ===========================================
# APP CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
